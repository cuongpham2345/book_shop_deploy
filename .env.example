# =============================================================
# Chỉ cần file này khi chạy KHÔNG dùng docker-compose
# (tức là chạy thẳng JAR hoặc deploy lên server)
# =============================================================

# Database
DB_URL=jdbc:mysql://localhost:3306/book_shop_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&useUnicode=true
DB_USERNAME=root
DB_PASSWORD=bookshop123

# RSA Keys (production - Railway, Heroku, ...)
# Khi chạy local/docker-compose thì KHÔNG cần set 2 biến này,
# ứng dụng tự đọc từ backend/src/main/resources/certs/
RSA_PUBLIC_KEY=<paste nội dung file certs/public-key.pem>
RSA_PRIVATE_KEY=<paste nội dung file certs/private-key.pem>
